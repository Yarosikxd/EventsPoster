@model EvensPoster.ViewsModels.EventCreateViewModel

<div class="container">
    <h2>Додати подію через URL фото</h2>
    <form asp-action="Create" method="post">
        <div class="mb-3">
            <label>Назва</label>
            <input asp-for="Title" class="form-control" />
        </div>

        <div class="mb-3">
            <label>Посилання на фото (URL)</label>
            <input asp-for="ImageUrl" class="form-control" placeholder="https://example.com" />
        </div>

        <div class="row">
            <div class="col-md-6">
                <label>Місто</label>
                <input asp-for="City" class="form-control" />
            </div>
            <div class="col-md-6">
                <label>Ціна</label>
                <input asp-for="Price" type="number" class="form-control" />
            </div>
        </div>

        <div class="mb-3 mt-3">
            <label>Дата</label>
            <input asp-for="Date" type="datetime-local" class="form-control" />
        </div>

        <div class="mb-3">
            <label>Опис</label>
            <textarea asp-for="Description" class="form-control"></textarea>
        </div>

        <button type="submit" class="btn btn-primary">Зберегти</button>
    </form>
</div>

